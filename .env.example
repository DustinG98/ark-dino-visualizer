# ----------------------------------------------------------------------------
# AI-Powered Alcohol Label Verification - environment configuration
# ----------------------------------------------------------------------------
# Copy this file to `.env` and edit for your deployment.
# `docker compose up` reads the root .env automatically.
# Real .env files are gitignored. Never commit secrets.
# ----------------------------------------------------------------------------

# ----------------------------------------------------------------------------
# Backend (FastAPI)
# ----------------------------------------------------------------------------

# Comma-separated list of origins allowed by CORS. In the production
# docker-compose setup, the front-end and back-end share an origin via
# the nginx reverse proxy, so the only entry that matters is the
# public hostname. Add localhost variants for debugging the API
# directly with curl.
ALLOWED_ORIGINS=http://localhost,https://your-domain.example

# Uvicorn server config. Each worker owns its own PaddleOCR engine.
UVICORN_HOST=0.0.0.0
UVICORN_PORT=8000
UVICORN_WORKERS=1
UVICORN_LOG_LEVEL=info

# Upload limits. Requests with a body larger than MAX_UPLOAD_SIZE_MB are
# rejected with 413. Batches with more than MAX_BATCH_SIZE images are
# rejected with 400.
MAX_UPLOAD_SIZE_MB=15
MAX_BATCH_SIZE=25

# PaddleOCR runtime
PADDLE_PDX_DISABLE_MODEL_SOURCE_CHECK=true

# ----------------------------------------------------------------------------
# TLS (Let's Encrypt via the bundled certbot service)
# ----------------------------------------------------------------------------

# Public hostname for which a Let's Encrypt certificate will be issued.
# Must resolve to the VPS IP before you start the stack. The certbot
# service uses the http-01 challenge via /.well-known/acme-challenge/,
# which is served by nginx on port 80.
CERTBOT_DOMAIN=your-domain.example

# Email for Let's Encrypt expiry notices.
CERTBOT_EMAIL=admin@your-domain.example

# Set to "true" to issue a staging cert (avoids Let's Encrypt rate
# limits during testing). Set to "false" or leave empty for production.
CERTBOT_STAGING=false

# ----------------------------------------------------------------------------
# Frontend (Vite / React)
# ----------------------------------------------------------------------------

# Base URL the front-end uses to reach the backend. In the production
# docker-compose setup, nginx reverse-proxies /api/* to the backend, so
# the front-end uses the same-origin path /api. The front-end appends
# `/analyze` to this base, so the final request URL is
# ${VITE_API_BASE_URL}/analyze.
VITE_API_BASE_URL=/api

# ----------------------------------------------------------------------------
# Discord Bot
# ----------------------------------------------------------------------------

# Required. The token for your Discord application. Create one in the
# Developer Portal, then invite the bot with the `bot` and
# `applications.commands` scopes.
DISCORD_BOT_TOKEN=

# Internal URL the bot uses to reach the backend. Defaults to
# http://backend:8000, the docker-compose service name. Override to
# http://localhost:8000 when running the bot outside docker for dev.
BACKEND_URL=http://backend:8000

# Optional. Set to a numeric guild ID to register slash commands
# instantly for that guild during development. Leave empty in
# production so commands register globally.
GUILD_ID=

# Bot log level (DEBUG / INFO / WARNING / ERROR). Mirrors the backend's
# UVICORN_LOG_LEVEL convention.
BOT_LOG_LEVEL=INFO

